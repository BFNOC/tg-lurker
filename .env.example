# Telegram API credentials (from https://my.telegram.org)
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Owner user ID (receives summaries via TG)
OWNER_ID=123456789

# LLM Configuration (any OpenAI-compatible API)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-api-key
LLM_MODEL=deepseek-chat
# API protocol: "chat" (/chat/completions) or "responses" (/responses)
LLM_API_FORMAT=chat
# Optional: separate proxy for LLM calls
# LLM_PROXY_URL=http://127.0.0.1:7897

# Schedule (cron expression, Asia/Shanghai timezone)
SUMMARY_CRON=0 22 * * *
SUMMARY_RETENTION_DAYS=7

# Storage paths
DB_PATH=./data/messages.db
SESSION_PATH=./data/lurker.session

# Telegram proxy (optional, for MTProto connection)
# PROXY_TYPE=socks5
# PROXY_HOST=127.0.0.1
# PROXY_PORT=1080

# Web UI
WEB_PORT=8080
WEB_PASSWORD=your-password-here
# Web 登录有效期（天）
WEB_SESSION_DAYS=30

# Telegram push (true/false)
TG_PUSH_ENABLED=true

# Timezone
TZ=Asia/Shanghai
